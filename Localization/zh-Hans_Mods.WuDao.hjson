	TheOutlaw: {
		DisplayName: 法外狂徒
		Messages.UltimateBomb: 终极爆弹

		Tooltip: {
			Base: 消耗子弹的霰弹枪。每秒射击 2 次，扇形散射，弹丸可穿透 3 个目标，每次穿透后伤害 -10%
			GrowthTitle: 成长解锁：

			Mark: {
				Ok: ✓
				No: ✗
			}

			LineFormat: "{0} {1}"

			Growth: {
				SlimeKing: 击败史莱姆王：每次射击发射 4 发霰弹
				QueenBee: 击败蜂王：每次射击发射 4~5 发霰弹（随机）
				Deerclops: 击败巨鹿：暴击后，下次射击发射 6 发并获得 +30% 伤害
				WallOfFlesh: 击败血肉墙：右键触发后跳（2 分钟冷却），短暂无敌；暴击减少 10 秒冷却
				AnyMechBoss: 击败任意机械 Boss：额外发射 1 枚分裂弹，命中后分裂成左右爆破弹
				Plantera: 击败世纪之花：分裂时必定生成 2 秒火墙，接触造成伤害
				AncientCultist: 击败拜月邪教徒：累计 4 次暴击后，下次射击发射【终极爆弹】（基础伤害×5，扇形溅射）
			}
		}
	}

