	NormalScissors: {
		DisplayName: 御剪

		Tooltip: {
			GrowthInfo: 成长型武器：会随击败特定 Boss 解锁能力

			QueenBee: {
				Unlocked: ✓ [蜂后已击败]：武器尺寸增大
