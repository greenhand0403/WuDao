Configs: {
	WishingWellConfig: {
		DoubleRewardPercent: {
			Label: Double Reward Chance (%)
			Tooltip: Chance that the wishing well gives double loot instead of summoning a boss
		}

		DisplayName: Wishing Well Config

		Chance: {
			Label: Chance
			Tooltip: Chance that the wishing well drops a reward
		}
	}

	WorldOfBlightConfig: {
		DisplayName: World Of Blight Config

		Enabled: {
			Label: Enable World Of Blight global effects
			Tooltip: ""
		}

		DamagePenaltyPerStep: {
			Label: Damage reduction per step (%)
			Tooltip: Each completed step reduces all damage you deal by a percentage. Range: 0%–10%. Default: 4%.
		}

		LifeRegenPenaltyPerStep: {
			Label: Life regeneration reduction per step (per second)
			Tooltip: Each completed step reduces your life regeneration by this amount per second. Range: 0–20. Default: 4. Note: Terraria internally counts life regen in half-seconds (per second ×2); the code will convert automatically.
		}

		DefensePenaltyPerStep: {
			Label: Defense reduction per step
			Tooltip: Each completed step reduces your defense by this amount. Range: 0–30. Default: 4.
		}

		DamageFloorMultiplier: {
			Label: Minimum damage multiplier
			Tooltip: Prevents damage from being reduced to 0. For example, 0.1 means you always keep at least 10% damage. Set to 0 to disable the minimum.
		}

		ClampLifeRegenNonNegative: {
			Label: Prevent this debuff from making life regen negative
			Tooltip: When enabled, World Of Blight can only reduce positive life regen down to 0, and will not make it negative. Enabled by default.
		}
	}

	BladeTrailConfig: {
		DisplayName: Blade Trail Config

		Headers: {
			CustomWhitelist: Whitelist Header
			DefaultSets: Include Default Blade Trail Set Header
			GlobalBladeTrail: Enable Vertex Blade Trail Header
		}

		EnableVertexBladeTrail: {
			Label: Enable Vertex Blade Trail
			Tooltip: The total switch enables global knife light staining by default
		}

		IncludeDefaultBladeTrailSet: {
			Label: Include Default Blade Trail Set
			Tooltip: The default collection has melee knife light enabled
		}

		IncludePhaseblades: {
			Label: Include Phaseblades
			Tooltip: By default, lightsaber's melee blade light is enabled
		}

		Whitelist: {
			Label: Whitelist
			Tooltip: Enable whitelisted melee sword light
		}
	}

	ArmorPrefixConfig: {
		PrefixMode: {
			Tooltip: Armor possesses the attributes of the five elements
			Label: Prefix Mode
		}

		DisplayName: Armor Prefix Config
		Headers.Main: Prefix Mode Header
	}

	WudaoConfig: {
		DisplayName: Wudao Config

		EnableJueXueSystem: {
			Label: Enable Jue Xue System
			Tooltip: The exclusive skill system is enabled by default
		}
	}

	ArmorPrefixMode: {
