Items: {
	NebulaRocket: {
		DisplayName: Nebula Rocket
		Tooltip: Fires a nebula rocket
	}

	SolarBullet: {
		DisplayName: Solar Bullet
		Tooltip: Fires an explosive bullet that inflicts the Daybreak debuff
	}

	SteelHeavySword: {
		DisplayName: Steel Heavy Sword
		Tooltip:
			'''
			Right-click to perform a heavy forward slash
			[c/AAAAAA:A blade without an edge]
			'''
	}

	WoodenShuriken: {
		DisplayName: Wooden Shuriken
		Tooltip: Throws a shuriken
	}

	GoldenShuriken: {
		DisplayName: Golden Shuriken
		Tooltip: Throws a shuriken with a chance to inflict the Midas debuff
	}

	FlyStone: {
		DisplayName: Fly Stone
		Tooltip: Throws a flying stone
	}

	WeaponBundleItem: {
		DisplayName: Weapon Bundle Item
		Tooltip: Contains WuDao Mod weapons, ammo, tools, accessories, etc.
		UIText: Choose your weapon bundle item
		ItemType0: Weapons
		ItemType1: Accessories
		ItemType2: Other
	}

	FlameShuriken: {
		DisplayName: Flame Shuriken
		Tooltip: Throws a shuriken with a chance to inflict On Fire!
	}

	IceShuriken: {
		DisplayName: Ice Shuriken
		Tooltip: Throws a shuriken with a chance to inflict Frostburn
	}

	PoisonedShuriken: {
		DisplayName: Poisoned Shuriken
		Tooltip: Throws a shuriken with a chance to inflict Poisoned
	}

	CactusNeedle: {
		DisplayName: Cactus Needle
		Tooltip: Throws a cactus needle
	}

	OceanBlueSword: {
		DisplayName: Ocean Blue Sword
		Tooltip:
			'''
			Grants underwater breathing, water walking, and swimming
			Immunity to Chilled and Frozen
			Fires ocean vortex projectiles
			Attacks may inflict Frostburn
			'''
	}

	HellfireSword: {
		DisplayName: Hellfire Sword
		Tooltip:
			'''
			Surrounded by a ring of fire
			Immunity to On Fire!, Burning, and Lava
			Fires hell slashes
			Attacks may inflict On Fire!
			'''
	}

	NormalScissors: {
		DisplayName: Normal Scissors

		Tooltip: {
			GrowthInfo: Evolving weapon: unlocks new abilities after defeating certain bosses.

			QueenBee: {
				Unlocked: ✓ [Queen Bee defeated]: Increased weapon size
				Locked: ✗ [Unlock after Queen Bee]: Increased weapon size
			}

			Skeletron: {
				Unlocked: ✓ [Skeletron defeated]: Build energy on hits → auto release a slash at full charge
				Locked: ✗ [Unlock after Skeletron]: Build energy → release a slash at full charge
			}

			WallOfFlesh: {
				Unlocked: ✓ [Wall of Flesh defeated]: Right-click dash slash (CD 1s)
				Locked: ✗ [Unlock after Wall of Flesh]: Right-click dash slash
			}

			Twins: {
				Unlocked: ✓ [The Twins defeated]: Extra wave on melee hit
				Locked: ✗ [Unlock after The Twins]: Wave on melee hit
			}

			Plantera: {
				Unlocked: ✓ [Plantera defeated]: Fires an extra Terra beam
				Locked: ✗ [Unlock after Plantera]: Fires an extra Terra beam
			}
		}

		Messages.EnergyFull: Energy Full
	}

	TimeStopItem: {
		DisplayName: Time Stop Item
		Tooltip:
			'''
			Freezes time for 5 seconds
			Only you can move, but you can still take damage
			[c/AAAAAA:Life is not about escaping before drowning]
			[c/AAAAAA:But swimming endlessly until thought itself ceases]
			'''
	}

	CloudArrow: {
		DisplayName: Cloud Arrow
		Tooltip: "[c/AAAAAA:One arrow pierces the clouds, and armies gather at its call]"
	}

	BrightVerdict: {
		DisplayName: Bright Verdict
		Tooltip: Shoots a sacred cross star
	}

	MagicHorn: {
		DisplayName: Magic Horn
		Tooltip: Fires random magic projectiles based on game progression
	}

	Mimicker: {
		DisplayName: Mimicker

		Tooltip: {
			$parentVal: ""
			RandomPoolSummary: Random Pool: {0} (Base Remain: {1}/{2}, Unlocked: {3})
			ProgressLine: "{0} needs {1} more to unlock {2}"
			MoreHidden: ... {0} more unlock goals not shown
		}

		UnlockCombatText: Unlocked: {0} projectile
		UnlockChatText: Mimicker: You unlocked the {0} projectile
		RemainCombatText: "{0} needs {1} more"
	}

	WindBlade: {
		DisplayName: Wind Blade
		Tooltip: Consumes mana to fire wind blades
	}

	ForestSword: {
		DisplayName: Forest Sword
		Tooltip: Move faster in the forest
	}

	ImmortalSword: {
		DisplayName: Immortal Sword
		Tooltip: Increases vitality
	}

	RainBowGolfClubs: {
		DisplayName: Rain Bow Golf Clubs
		Tooltip: Fires random golf balls
	}

	SteelBroadSword: {
		DisplayName: Steel Broad Sword
		Tooltip: Emits sword light when swung
	}

	SteelShortSword: {
		DisplayName: Steel Short Sword
		Tooltip: Move faster during the daytime
	}

	HarpyWingSword: {
		DisplayName: Harpy Wing Sword
		Tooltip: Fires harpy feathers and excels in aerial combat
	}

	SmokeGrenade: {
		DisplayName: Smoke Grenade
		Tooltip: Leaves behind damaging smoke
	}

	TheOutlaw: {
		DisplayName: The Outlaw
		Messages.UltimateBomb: ULTIMATE BOMB!

		Tooltip: {
			Base: A bullet-consuming shotgun. Fires twice per second in a cone. Pellets pierce up to 3 targets, losing 10% damage per pierce.
			GrowthTitle: Growth Unlocks:

			Mark: {
				Ok: ✓
				No: ✗
			}

			LineFormat: "{0} {1}"

			Growth: {
				SlimeKing: Defeat King Slime: fires 4 pellets per shot
				QueenBee: Defeat Queen Bee: fires 4–5 pellets per shot (random)
				Deerclops: Defeat Deerclops: after a crit, next shot fires 6 pellets and gains +30% damage
				WallOfFlesh: Defeat Wall of Flesh: right-click backstep (2 min cooldown), brief immunity; crit reduces cooldown by 10s
				AnyMechBoss: Defeat any Mechanical Boss: fires 1 extra split shot that breaks into left/right bomblets on hit
				Plantera: Defeat Plantera: split shots always create a 2s firewall on split
				AncientCultist: Defeat Lunatic Cultist: after 4 crits, next shot fires an ULTIMATE BOMB (x5 base damage, cone splash)
			}
		}
	}

	GhostChakram: {
		DisplayName: Ghost Chakram
		Tooltip: Increases in size and damage when passing through enemies
	}

	InvincibleBlade: {
		DisplayName: Invincible Blade
		Tooltip:
			'''
			Deals damage based on a percentage of enemy max life
			[c/C040FF:No enemy is unbeatable]
			[c/AAAAAA:I wished for invincibility and ended up with zero damage]
			'''
	}

	DevolutionCharm: {
		DisplayName: Devolution Charm
		Tooltip: Enemies within a 30-block radius deal 10% less damage and 10% increased damage taken
	}

	WrathLotus: {
		DisplayName: Wrath Lotus
		Tooltip: Reflects damage when hurt and grants immunity to Burning and On Fire!
	}

	DiscoBallRemote: {
		DisplayName: Disco Ball Remote
		Tooltip: A dazzling disco ball
	}

	BlasterPliers: {
		DisplayName: Blaster Pliers
		Tooltip:
			'''
			Hotdogs in your inventory increase this weapon's damage
			[c/C040FF:Juicy bite]
			'''
	}

	RewinderCicadas: {
		DisplayName: Rewinder Cicadas
		Tooltip: 
			'''
			When mortally wounded, restore health to 3 seconds ago
			[c/FFD700: Spring and Autumn Cicadas Return of the Youth]
			'''
		Messages: {
			RewindTriggered: Rewinder Cicadas returned to the Time River
			Heal: Healed {0} life
		}
	}

	Cookbook: {
		DisplayName: Cookbook

		Tooltip: {
			$parentVal: ""
			MadeCount: Crafted: {0} / {1} foods
			CookingSkill: Cooking skill: {0}
			TodayRecommend: Today's recommendation: {0}
			NoRecipeHint: No recipe (may be drop / purchase / crate / goodie bag)
		}
	}

	FoodLogItem: {
		DisplayName: Food Log Item

		Tooltip: {
			$parentVal: ""
			ClosedName: Food Log
			ClosedHint: Favorite this item to show suggestions for foods you haven't tried.
			EatenProgress: Eaten: {0} / {1} foods
			Deliciousness: Deliciousness: {0}
			SuggestionsTitle: Go taste these foods!(Suitable by the sea)
		}
	}

