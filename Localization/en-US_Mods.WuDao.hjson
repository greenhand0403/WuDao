	HeartArrow: {
		DisplayName: Heart Arrow
		Tooltip:
			'''
			Consumes 2 life
			Weak homing ability
			Restores 1 life on hit
			Killing enemies drops healing hearts
			[c/FF4040:Even love cannot stop life from fading]
			'''
	}

	CupidBow: {
		DisplayName: Cupid Bow
		Tooltip:
			'''
			Converts Wooden Arrows into Heart Arrows
