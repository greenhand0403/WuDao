			'''
	}

	ApeTouch: {
		DisplayName: Ape Touch
		Tooltip:
			'''
			When life is below 51%
			Taking damage consumes double mana to negate 50% contact damage (fails if insufficient mana)
			Touching friendly units restores 5 life per second
			'''
	}

	NearsightedGlasses: {
		DisplayName: Nearsighted Glasses
		Tooltip:
			'''
			Grants different effects based on distance to enemies
